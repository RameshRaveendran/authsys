# Server Configuration
PORT=5000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/auth-system

# MailTrap Configuration (Email Service)
# Get credentials from: https://mailtrap.io/
# 1. Sign up for free account at mailtrap.io
# 2. Go to Sending > Integrations > NodeMailer
# 3. Copy the credentials below

MAILTRAP_HOST=smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=your_mailtrap_username_here
MAILTRAP_PASS=your_mailtrap_password_here
MAILTRAP_FROM=noreply@authsystem.com

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# Encryption Configuration  
ENCRYPTION_KEY=your_encryption_key_here
