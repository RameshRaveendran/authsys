        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"testuser@mailinator.com\",\n  \"password\": \"TestPass123\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/api/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "auth", "login"]
        }
      }
    }
  ]
}
